# Environment Variables

# OpenAI (Primary LLM & Embeddings)
OPENAI_API_KEY=your_openai_api_key_here

# Fallback LLM (Optional)
GEMINI_API_KEY=your_gemini_api_key_here

# Local Ollama LLM (for metadata extraction during ingestion)
# Set this to your Ollama model name (e.g. llama3, mistral, qwen2, phi3)
# If not set, the ingestion pipeline will fall back to regex-only extraction.
# OLLAMA_MODEL=gemma4:e4b-mlx
OLLAMA_MODEL=gpt-oss:120b-cloud
OLLAMA_BASE_URL=http://localhost:11434
# Embeddings require a model with Ollama's embedding capability; do not reuse
# a chat model such as gpt-oss. Install one first: ollama pull embeddinggemma
# OLLAMA_EMBEDDING_MODEL=embeddinggemma

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ps8_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Chroma Vector DB
CHROMA_DB_DIR=./chroma_data
